{
  "expo": {
    "name": "Almanac",
    "slug": "almanac",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "almanac",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./landing-page.png",
      "resizeMode": "cover",
      "backgroundColor": "#F5EDD8"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "assets": [
      "./assets/splash-page/bg-rays.svg",
      "./assets/splash-page/tv-body.svg",
      "./assets/splash-page/text-bg.svg",
      "./assets/splash-page/icon-close.svg",
      "./assets/splash-page/icon-cursor.svg",
      "./assets/splash-page/icon-folder.svg",
      "./assets/splash-page/icon-warning.svg"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.almanac.habits"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#F5E6C8",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.almanac.habits"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
